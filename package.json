{
  "name": "ingenia",
  "version": "1.1.0",
  "description": "IngenIA - Chat y compara modelos de Ollama",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "vite & electron .",
    "electron:dev:win": "start /b cmd /c vite & electron .",
    "start": "electron .",
    "serve": "node server.mjs",
    "dist:linux": "electron-builder --linux",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:all": "electron-builder --linux --win --mac"
  },
  "build": {
    "appId": "com.ingenia.app",
    "productName": "IngenIA",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "public/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "public",
        "to": "public"
      }
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "public/icon.png",
      "category": "Utility"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "public/icon.ico"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "public/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": {
      "provider": "github",
      "owner": "josemanueb",
      "repo": "IngenIA",
      "releaseType": "release"
    }
  },
  "dependencies": {
    "electron-updater": "^6.6.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.5.2",
    "electron": "^35.3.0",
    "electron-builder": "^25.1.8",
    "vite": "^6.3.5"
  }
}
